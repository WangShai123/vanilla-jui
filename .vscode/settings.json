{
  "cSpell.words": [
    "abcdefghijkmnpqrstuvwxyz",
    "cpolyline",
    "hoverable",
    "iemobile",
    "labelledby",
    "maxlength"
  ],

  "textMinify.suffix": "min",
  "textMinify.dropConsole": false,
  "textMinify.fileExtensions": {
    "css": false,
    "js": false,
    "json": false
  },
  "jsMinifyObfuscator.enableAutoSave": false,
  "jsMinifyObfuscator.enableMinify": true,
  "jsMinifyObfuscator.minifySuffix": ".min",
  "jsMinifyObfuscator.enableObfuscator": false,
  "jsMinifyObfuscator.enableTsNoCheck": false,
  "jsMinifyObfuscator.obfuscatorLevel": "high",
  "jsMinifyObfuscator.customObfuscatorOptions": {
    "compact": true,
    "controlFlowFlattening": false,
    "deadCodeInjection": false,
    "debugProtection": false,
    "stringArray": false,
    "identifierNamesGenerator": "mangled",
    "renameGlobals": true
  },
  "jsMinifyObfuscator.minifyTerserOptions": {
    "compress": {
      "drop_console": true,
      "drop_debugger": true
    },
    "mangle": {
      "toplevel": true
    }
  },

  "npm.scriptRunner": "vp",
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "[javascript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "oxc.fmt.configPath": "./vite.config.ts",
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "explicit"
  }
}
